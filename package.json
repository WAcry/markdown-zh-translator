{
  "name": "markdown-zh-translator",
  "displayName": "Markdown Zh Translator",
  "description": "Translate Markdown files to zh-CN inside VS Code.",
  "version": "0.1.1",
  "publisher": "david-zhang-wacry",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/WAcry/markdown-zh-translator.git"
  },
  "engines": {
    "vscode": "^1.97.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:markdownTranslator.translateCurrentDocument",
    "onCommand:markdownTranslator.forceTranslateCurrentDocument",
    "onCommand:markdownTranslator.setApiKey",
    "onCommand:markdownTranslator.clearApiKey"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdownTranslator.translateCurrentDocument",
        "title": "Translate to Chinese",
        "icon": "$(globe)"
      },
      {
        "command": "markdownTranslator.forceTranslateCurrentDocument",
        "title": "Force Refresh Chinese Translation",
        "icon": "$(refresh)"
      },
      {
        "command": "markdownTranslator.setApiKey",
        "title": "Markdown Translator: Set API Key"
      },
      {
        "command": "markdownTranslator.clearApiKey",
        "title": "Markdown Translator: Clear API Key"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "markdownTranslator.translateCurrentDocument",
          "group": "navigation",
          "when": "resourceLangId == markdown && resourceExtname == .md && isFileSystemResource && !(resourceFilename =~ /\\.zh-CN\\.md$/i)"
        },
        {
          "command": "markdownTranslator.forceTranslateCurrentDocument",
          "group": "navigation@2",
          "when": "resourceLangId == markdown && resourceExtname == .md && isFileSystemResource && !(resourceFilename =~ /\\.zh-CN\\.md$/i)"
        }
      ]
    },
    "configuration": {
      "title": "Markdown Translator",
      "properties": {
        "markdownTranslator.baseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "Base URL for the OpenAI-compatible API."
        },
        "markdownTranslator.model": {
          "type": "string",
          "default": "",
          "description": "Model name used for Markdown translation."
        },
        "markdownTranslator.requestTimeoutMs": {
          "type": "number",
          "default": 120000,
          "minimum": 1000,
          "description": "HTTP timeout for translation requests in milliseconds."
        },
        "markdownTranslator.systemPrompt": {
          "type": "string",
          "default": "",
          "description": "Optional extra system prompt appended to the built-in Markdown translation rules."
        },
        "markdownTranslator.localBlobCacheMaxBytes": {
          "type": "number",
          "default": 10485760,
          "minimum": 0,
          "description": "Maximum size in bytes for the persistent local translated Markdown blob cache."
        },
        "markdownTranslator.deleteTranslatedOnClose": {
          "type": "boolean",
          "default": false,
          "description": "When enabled, closing an untouched generated .zh-CN.md document deletes only the workspace copy and keeps the local blob cache."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:extension",
    "build:extension": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && npx --no-install esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=dist/extension.js",
    "compile": "node -e \"require('node:fs').rmSync('out', { recursive: true, force: true })\" && npx --no-install tsc -p ./",
    "watch": "npx --no-install tsc -watch -p ./",
    "lint": "npx --no-install eslint \"src/**/*.ts\"",
    "test": "npm run compile && npx --no-install mocha \"out/test/**/*.test.js\"",
    "package:vsix": "node scripts/package-vsix.cjs"
  },
  "dependencies": {
    "undici": "^6.21.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.13.1",
    "@types/vscode": "^1.97.0",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "@vscode/vsce": "^3.2.2",
    "esbuild": "^0.25.1",
    "eslint": "^9.20.0",
    "globals": "^15.14.0",
    "mocha": "^11.1.0",
    "typescript": "^5.7.3"
  }
}
